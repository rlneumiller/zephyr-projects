/ {
	model = "wifi-uart-bridge";

	cpus {
		/* Use the default CPU node from the SoC */
	};
};

&uart0 {
	status = "okay";
	current-speed = <115200>;
	pinctrl-0 = <&uart0_default>;
	pinctrl-names = "default";
	/* zephyr,pm-device-disabled; */
};

&wifi {
    /* zephyr,pm-device-disabled;*/
};


&spi2 {
	status = "disabled";
};

&pinctrl {
	uart0_default: uart0_default {
		group1 {
			pinmux = <UART0_TX_GPIO4>;
			output-high;
		};
		group2 {
			pinmux = <UART0_RX_GPIO5>;
			bias-pull-up;
		};
	};
};

&wifi {
	/* zephyr,pm-device-disabled; */
};